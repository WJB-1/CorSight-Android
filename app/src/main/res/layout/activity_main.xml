<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 地图铺满全屏 -->
    <com.amap.api.maps.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 水印 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="36dp"
        android:text="瞳心引航"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#60FFFFFF"
        android:elevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 导航信息浮层（地图上方） -->
    <LinearLayout
        android:id="@+id/layout_nav_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="56dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/card_background"
        android:visibility="gone"
        android:elevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_nav_distance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:text="0m" />

            <TextView
                android:id="@+id/tv_nav_duration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:text="0分钟"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_nav_instruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 搜索建议列表（浮动在搜索栏下方，固定高度区域，内部滚动） -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_suggestions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar_container"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls"
        app:layout_constrainedHeight="true">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_suggestions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

    </androidx.cardview.widget.CardView>

    <!-- 定位按钮（地图右下角） -->
    <ImageButton
        android:id="@+id/btn_my_location"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/card_background"
        android:src="@android:drawable/ic_menu_mylocation"
        android:tint="?android:attr/textColorPrimary"
        android:elevation="4dp"
        android:contentDescription="定位"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls" />

    <!-- 搜索栏（浮在地图上方，居中偏上） -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_bar_container"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="?android:attr/textColorSecondary" />

            <EditText
                android:id="@+id/et_destination"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@null"
                android:hint="搜索目的地"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/btn_clear_search"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="?android:attr/textColorSecondary"
                android:visibility="gone"
                android:contentDescription="清除" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 页面容器（历史、设置）覆盖全屏 -->
    <FrameLayout
        android:id="@+id/container_pages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include
            android:id="@+id/page_history"
            layout="@layout/page_history"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/page_settings"
            layout="@layout/page_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- 底部功能按钮组（约束在 BottomNav 上方） -->
    <LinearLayout
        android:id="@+id/bottom_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="?android:attr/colorBackground"
        android:elevation="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <!-- 导航按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btn_start_navigation"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="开始导航"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="@color/teal_200" />

            <Button
                android:id="@+id/btn_preview_route"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="行前预览"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="@color/purple_500" />
        </LinearLayout>

        <!-- 视觉避障按钮 -->
        <Button
            android:id="@+id/btn_vision_test"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:text="视觉避障检测"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@color/vision_green"
            android:drawableStart="@drawable/ic_vision"
            android:drawablePadding="8dp"
            android:gravity="center" />

        <!-- 按住说话按钮 -->
        <FrameLayout
            android:id="@+id/btn_voice_container"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_voice_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_microphone"
                    android:tint="@color/white" />

                <TextView
                    android:id="@+id/tv_voice_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="按住说话"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
            </LinearLayout>

            <View
                android:id="@+id/voice_ripple"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_voice_button_active"
                android:visibility="gone" />
        </FrameLayout>

        <!-- 停止语音按钮 -->
        <Button
            android:id="@+id/btn_stop_tts"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="停止语音"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@color/gray"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 底部导航栏（固定在底部） -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        app:menu="@menu/menu_main_bottom"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
